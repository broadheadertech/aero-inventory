# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# claude code
.claude/

# bmad workflow artifacts
_bmad/
_bmad-output/

# typescript
*.tsbuildinfo
next-env.d.ts

# convex generated files (regenerated by `npx convex dev`)
# scaffold stubs in convex/_generated/ are tracked during local dev without
# real Convex credentials; once real credentials are set, run `npx convex dev`
# and commit the real generated files in place of the stubs.
# convex/_generated/
